# Supabase credentials (get from Supabase dashboard → Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Path to the folder containing your Excel files
# Use forward slashes even on Windows: C:/Users/You/OneDrive/Dispatch/
EXCEL_DIR=./

# How often to sync (in seconds). Default: 300 = every 5 minutes
SYNC_INTERVAL_SECONDS=300
