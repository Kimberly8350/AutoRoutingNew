# Supabase credentials (get from Supabase dashboard → Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Path to the folder containing your Excel files (yard, terminal, site, driver tables)
# Use forward slashes even on Windows: C:/Users/You/OneDrive/Dispatch/
EXCEL_DIR=./

# CE Connect MySQL — used for load_details (vw_undelivered_loads)
CE_CONNECT_HOST=your-mysql-host
CE_CONNECT_PORT=3306
CE_CONNECT_USER=your-db-user
CE_CONNECT_PASSWORD=your-db-password
CE_CONNECT_DATABASE=your-database-name

# How often to sync (in seconds). Default: 300 = every 5 minutes
SYNC_INTERVAL_SECONDS=300
